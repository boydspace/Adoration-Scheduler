{
    "name": "fatherboyd/adoration-scheduler",
    "description": "A scheduling system for Eucharistic Adoration (WordPress plugin).",
    "type": "wordpress-plugin",
    "license": "proprietary",
    "require": {
        "php": ">=8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6",
        "wp-phpunit/wp-phpunit": "^6.0",
        "yoast/phpunit-polyfills": "^2.0"
    },
    "autoload-dev": {
        "psr-4": {
            "AdorationScheduler\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite unit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --configuration phpunit-integration.xml.dist"
    },
    "config": {
        "sort-packages": true
    }
}
