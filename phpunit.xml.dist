<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/9.3/phpunit.xsd"
         bootstrap="tests/bootstrap.php"
         colors="true"
         cacheResultFile=".phpunit.cache/unit.result.cache"
         beStrictAboutOutputDuringTests="true">

    <testsuites>
        <!--
            Fast, no-WordPress-install-needed tests. Real WordPress functions are
            stubbed with Brain Monkey (see tests/Support/AdorationTestCase.php) and
            $wpdb is a lightweight in-memory double (tests/Support/FakeWpdb.php) —
            neither PHP nor MySQL from the actual site is involved. Safe to run
            anywhere, including CI.
        -->
        <testsuite name="unit">
            <directory>tests/Unit</directory>
        </testsuite>
    </testsuites>

    <!--
        The integration suite (tests/Integration) runs against a real WordPress +
        MySQL install and needs a different bootstrap than this file provides —
        see phpunit-integration.xml.dist / `composer test:integration` and
        tests/Integration/README.md.
    -->

    <coverage>
        <include>
            <directory suffix=".php">includes</directory>
        </include>
    </coverage>
</phpunit>
